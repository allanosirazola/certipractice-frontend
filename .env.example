# CertiPractice Frontend — Environment variables
# Copy this file to `.env.local` and adjust the values for your environment.

# Backend API URL. Defaults to the production Railway deployment if unset.
# Examples:
#   VITE_API_URL=http://localhost:3000
#   VITE_API_URL=https://api.example.com
VITE_API_URL=http://localhost:3000

# Admin panel API URL. Falls back to VITE_API_URL when not set.
# Use this to point the admin panel to a different backend (e.g. staging).
#   VITE_ADMIN_API_URL=https://api.example.com
VITE_ADMIN_API_URL=
